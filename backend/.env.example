# Claude API for the quant agent. Copy this file to .env and fill in.
# QUANT_ 前缀避免与运行环境里 Claude Code 自身的 ANTHROPIC_* 变量冲突。
QUANT_ANTHROPIC_API_KEY=
# Optional: custom endpoint (proxy / relay). Leave blank to use the official API.
QUANT_ANTHROPIC_BASE_URL=
# Model id used by the agent.
QUANT_ANTHROPIC_MODEL=claude-sonnet-4-6

# Django
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=True

# PostgreSQL. Leave POSTGRES_DB blank to fall back to the local SQLite file.
# These match docker-compose.yml; `docker compose up -d` then fill them in .env.
POSTGRES_DB=quant
POSTGRES_USER=quant
POSTGRES_PASSWORD=quant_dev_pw
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
